{
  "name": "zeroxai",
  "version": "1.0.0",
  "description": "ZeroxAI — современный AI-ассистент",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "author": "ZeroxAI",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^24.7.0"
  },
  "build": {
    "appId": "com.zeroxai.desktop",
    "productName": "ZeroxAI",
    "artifactName": "ZeroxSetup-${version}.${ext}",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron/**",
      "index.html",
      "src/**",
      "assets/**",
      "Animations/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/logo.svg"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZeroxAI",
      "artifactName": "ZeroxSetup-${version}.${ext}"
    }
  }
}
