{
  "name": "zeroxai",
  "version": "1.0.0",
  "description": "ZeroxAI Telegram Desktop Client",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "electron:build": "electron-builder"
  },
  "keywords": ["telegram", "zeroxai"],
  "author": "ZeroxAI",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^26.4.0",
    "electron-builder": "^24.7.0"
  },
  "build": {
    "appId": "com.zeroxai.desktop",
    "productName": "ZeroxAI Telegram",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron/**",
      "package.json",
      ".env"
    ],
    "extraResources": [
      {
        "from": "ZeroxAiApp",
        "to": "ZeroxAiApp",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["portable"]
    }
  }
}
